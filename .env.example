# AI provider: "zai" (default) or "gemini"
AI_PROVIDER=gemini

# z.ai (default once balance is restored)
#Z_AI_API_KEY=your_z_ai_api_key_here
#Z_AI_BASE_URL=https://api.z.ai/api/paas/v4/
#Z_AI_MODEL=glm-4.6

# Gemini (free tier on https://aistudio.google.com/app/apikey).
# Uses Google's OpenAI-compatible endpoint, so no extra SDK is needed.
GEMINI_API_KEY=AIzaSyBdMoB7PcLWl9UILiD44w9PHk0vrfJ6qo8
GEMINI_MODEL=gemini-2.5-flash
#GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

#PORT=8000

# Optional: leave blank to disable the Telegram bot.
# Create a bot via @BotFather on Telegram and paste the token here.
# For group usage, also disable Group Privacy in BotFather (Bot Settings → Group Privacy → Turn off).
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLL_INTERVAL_MS=1500

