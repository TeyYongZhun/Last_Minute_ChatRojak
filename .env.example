# Copy this file to .env and fill in your values.
# Never commit real keys — .env.example is not gitignored.

# --- AI provider ---
# 'anthropic' (default, Claude), 'zai' (GLM-4.6), or 'gemini'.
AI_PROVIDER=anthropic

# Anthropic / Claude (default). Leave ANTHROPIC_BASE_URL blank for the
# official API, or point it at an Anthropic-compatible proxy.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-6

# z.ai (only used when AI_PROVIDER=zai)
Z_AI_API_KEY=
Z_AI_BASE_URL=https://api.z.ai/api/paas/v4/
Z_AI_MODEL=glm-4.6

# Gemini (only used when AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Server ---
PORT=8000
SESSION_SECRET=change-me-to-a-random-64-char-hex-string
DB_PATH=state/app.db

# --- Google Calendar OAuth (optional) ---
# Required for calendar sync. Create OAuth2 Web credentials at
# https://console.cloud.google.com/apis/credentials and add
# GOOGLE_REDIRECT_URI to the authorized redirect URIs list.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/google/auth/callback

# --- Telegram bot (optional) ---
# Create a bot via @BotFather and paste the token below.
TELEGRAM_BOT_TOKEN=
