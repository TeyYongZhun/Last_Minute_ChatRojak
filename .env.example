# Switch between providers without editing code:
AI_PROVIDER=zai

# z.ai (canonical)
Z_AI_API_KEY=
Z_AI_BASE_URL=https://api.z.ai/api/paas/v4/
Z_AI_MODEL=glm-4.6

# Gemini (alternative)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Server
PORT=8000

# Signed-cookie secret for sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Optional: override SQLite path (default: state/app.db)
# DB_PATH=state/app.db

# Optional: Telegram bot token to enable the /link flow + push notifications
# TELEGRAM_BOT_TOKEN=
